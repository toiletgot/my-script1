-- 完全終了（❌）
local connection
closeBtn.MouseButton1Click:Connect(function()
    if connection then connection:Disconnect() end
    hoveringObjects = {}
    grabbed = nil
    holding = false
    gui:Destroy()
end)

-- ボタン機能（掴む/スピン/ホバリング/投げる）
toggleBtn.MouseButton1Click:Connect(function()
    enabled = not enabled
    toggleBtn.Text = enabled and "掴むON" or "掴むOFF"
end)
spinBtn.MouseButton1Click:Connect(function()
    spinEnabled = not spinEnabled
    spinBtn.Text = spinEnabled and "Spin ON" or "Spin OFF"
end)
hoverBtn.MouseButton1Click:Connect(function()
    if grabbed then
        hoveringObjects[grabbed]=true
        grabbed.Anchored=false
        holding=false
    end
end)
throwBtn.MouseButton1Click:Connect(function()
    if grabbed then
        hoveringObjects[grabbed]=nil
        grabbed.AssemblyLinearVelocity=camera.CFrame.LookVector*flingPower
        grabbed=nil
        holding=false
    end
    for obj,_ in pairs(hoveringObjects) do
        if obj and obj.Parent then
            hoveringObjects[obj]=nil
            obj.AssemblyLinearVelocity=camera.CFrame.LookVector*flingPower
        end
    end
end)

-- 数値入力（上限なし）
distBox.FocusLost:Connect(function()
    local n = tonumber(distBox.Text)
    if n then distance = n end
    distBox.Text = tostring(distance)
end)
spinBox.FocusLost:Connect(function()
    local n = tonumber(spinBox.Text)
    if n then spinSpeed = n end
    spinBox.Text = tostring(spinSpeed)
end)
powerBox.FocusLost:Connect(function()
    local n = tonumber(powerBox.Text)
    if n then flingPower = n end
    powerBox.Text = tostring(flingPower)
end)
hoverBox.FocusLost:Connect(function()
    local n = tonumber(hoverBox.Text)
    if n then hoverHeight = n end
    hoverBox.Text = tostring(hoverHeight)
end)

-- 掴む＆スピン＆ホバリング
local function canGrab(part)
    return part and not part.Anchored and not part:IsDescendantOf(player.Character)
end
local function getTarget()
    local origin=camera.CFrame.Position
    local direction=camera.CFrame.LookVector*20
    local rp=RaycastParams.new()
    rp.FilterDescendantsInstances={player.Character}
    rp.FilterType=Enum.RaycastFilterType.Blacklist
    local result=workspace:Raycast(origin,direction,rp)
    return result and result.Instance
end

connection = RunService.RenderStepped:Connect(function()
    if enabled then
        local target=getTarget()
        if target and canGrab(target) then
            grabbed=target
            holding=true
            spinAngle=0
        end
        if holding and grabbed and grabbed.Parent then
            local hrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local pos=hrp.CFrame*CFrame.new(0,0,-distance)
                if spinEnabled then spinAngle+=spinSpeed; pos=pos*CFrame.Angles(0,spinAngle,0) end
                grabbed.CFrame=grabbed.CFrame:Lerp(pos,0.4)
            end
        end
    end

    for obj,_ in pairs(hoveringObjects) do
        if obj and obj.Parent then
            local targetY = player.Character.HumanoidRootPart.Position.Y + hoverHeight
            local targetPos = Vector3.new(obj.Position.X,targetY,obj.Position.Z)
            obj.CFrame=CFrame.new(targetPos)
        else
            hoveringObjects[obj]=nil
        end
    end
end)
