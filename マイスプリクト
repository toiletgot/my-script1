-- スクロールフレーム
local scrollFrame = Instance.new("ScrollingFrame", main)
scrollFrame.Size = UDim2.new(1,0,1,-20)
scrollFrame.Position = UDim2.new(0,0,0,20)
scrollFrame.CanvasSize = UDim2.new(0,0,0,300)
