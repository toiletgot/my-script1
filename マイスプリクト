scrollFrame.BackgroundTransparency = 1

-- 小型ボタン作成関数
local function makeBtn(text, y)
    local b = Instance.new("TextButton", scrollFrame)
    b.Size = UDim2.new(1,-10,0,15)
    b.Position = UDim2.new(0,5,0,y)
    b.Text = text
    b.BackgroundColor3 = Color3.fromRGB(80,80,80)
    b.TextColor3 = Color3.fromRGB(255,255,255)
    b.TextScaled = true
    return b
end

local toggleBtn = makeBtn("掴むOFF",0)
local spinBtn = makeBtn("Spin OFF",20)
local hoverBtn = makeBtn("空中浮かす",40)
local throwBtn = makeBtn("投げる",60)

-- 名前付き小型数値入力作成関数
local function makeLabeledBox(name, default, y)
    local label = Instance.new("TextLabel", scrollFrame)
    label.Size = UDim2.new(1,-10,0,10)
    label.Position = UDim2.new(0,5,0,y)
    label.Text = name
    label.BackgroundColor3 = Color3.fromRGB(50,50,50)
    label.TextColor3 = Color3.fromRGB(255,255,255)
    label.TextScaled = true

    local box = Instance.new("TextBox", scrollFrame)
    box.Size = UDim2.new(1,-10,0,15)
    box.Position = UDim2.new(0,5,0,y+10)
    box.Text = tostring(default)
    box.BackgroundColor3 = Color3.fromRGB(80,80,80)
    box.TextColor3 = Color3.fromRGB(255,255,255)
    box.ClearTextOnFocus = false
    box.TextScaled = true
    return box
end

local distBox = makeLabeledBox("掴む距離", distance, 80)
local spinBox = makeLabeledBox("回転速度", spinSpeed, 110)
local powerBox = makeLabeledBox("投げる力", flingPower, 140)
local hoverBox = makeLabeledBox("ホバリング高さ", hoverHeight, 170)

-- ドラック処理（PC + タッチ対応）
local dragging = false
local dragStart = Vector2.new()
local startPos = UDim2.new()

local function startDrag(input)
    dragging = true
    dragStart = input.Position
    startPos = main.Position
end

local function updateDrag(input)
    if dragging then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end

local function endDrag()
    dragging = false
end

dragBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        startDrag(input)
    end
end)
dragBtn.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        updateDrag(input)
    end
end)
UIS.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        updateDrag(input)
    end
end)
dragBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        endDrag()
    end
end)

-- UIサイズ切替
